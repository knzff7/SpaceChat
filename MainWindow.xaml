<Window x:Class="SpaceChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Space P2P" Height="650" Width="1000" 
        Background="#F0F2F5"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" CornerRadius="0,25,25,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>
            
            <StackPanel Margin="20">
                <TextBlock Text="🚀 SPACE CHAT" FontSize="22" FontWeight="ExtraBold" 
                           Foreground="#6C5CE7" Margin="0,0,0,20"/>

                <Border Background="#ECF0F1" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                    <TextBlock x:Name="StatusText" Text="⏳ Подключение..." 
                               FontSize="10" Foreground="#7F8C8D" TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>

                <Button Content="🔄 Переподключиться" Click="ReconnectButton_Click"
                        Margin="0,0,0,20" Height="35" Background="#3498DB" Foreground="White" FontSize="13"/>

                <Separator Margin="0,0,0,15" Background="#ECF0F1"/>

                <TextBlock Text="🎙️ ГОЛОСОВЫЕ КАНАЛЫ" FontSize="11" FontWeight="Bold" 
                           Foreground="#B2BEC3" Margin="0,0,0,10"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="300">
                    <ItemsControl x:Name="ChannelsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Margin="0,4" Padding="12,9" 
                                        Click="ChannelButton_Click"
                                        Background="#F8F9FA" BorderThickness="0" 
                                        HorizontalContentAlignment="Left" FontSize="13">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E8E9FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Content="➕ Создать канал" Click="AddChannel_Click" 
                        Margin="0,15,0,0" Height="42" Background="#6C5CE7" Foreground="White" 
                        FontWeight="Bold" FontSize="13" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Border Background="#DFE6E9" CornerRadius="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📺" FontSize="90" Margin="0,0,0,20"/>
                    <TextBlock Text="Экран готов к трансляции" FontSize="18" FontWeight="SemiBold" Foreground="#636E72"/>
                </StackPanel>
            </Border>

            <Button Content="🎥 Транслировать экран" Click="StartScreenShare_Click"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40"
                    Width="260" Height="50" Background="#6C5CE7" Foreground="White" FontSize="14" FontWeight="Bold"/>
        </Grid>
    </Grid>
</Window>